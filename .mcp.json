{
  "mcpServers": {
    "exact-online": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@cdata/exact-online-mcp-server"],
      "env": {
        "EXACTONLINE_CLIENTID": "${EXACTONLINE_CLIENTID}",
        "EXACTONLINE_CLIENTSECRET": "${EXACTONLINE_CLIENTSECRET}",
        "EXACTONLINE_DIVISION": "${EXACTONLINE_DIVISION}",
        "MOLLIE_API_OAUTH_ORG_TOKEN": "${MOLLIE_API_OAUTH_ORG_TOKEN}"
      }
    },
    "Mollie": {
      "command": "npx",
       "args": [
        "mcp-remote",
        "https://mcp.mollie.com/mcp",
        "--header",
        "Authorization: Bearer ${MOLLIE_API_OAUTH_ORG_TOKEN}"
      ],
      "env": {
        "MOLLIE_API_OAUTH_ORG_TOKEN": "PUT_YOUR_OWN_ORG_TOKEN_HERE"
      }
    },
    "paypal": {
      "type": "http",
      "url": "https://mcp.paypal.com/mcp"
    },
    "sumup": {
      "type": "http",
      "url": "https://mcp.sumup.com/mcp"
    },
    "hubspot": {
      "type": "http",
      "url": "https://mcp.hubspot.com/anthropic"
    },
    "brevo": {
      "type": "http",
      "url": "https://mcp.brevo.com/v1/brevo/mcp"
    },
    "pipedrive": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-pipedrive"],
      "env": {
        "PIPEDRIVE_API_TOKEN": "${PIPEDRIVE_API_TOKEN}"
      }
    },
    "canva": {
      "type": "http",
      "url": "https://mcp.canva.com/mcp"
    },
    "docusign": {
      "type": "http",
      "url": "https://mcp.docusign.com/mcp"
    },
    "calendly": {
      "type": "http",
      "url": "https://mcp.calendly.com"
    },
    "slack": {
      "type": "http",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118
      }
    },
    "ms365": {
      "type": "http",
      "url": "https://microsoft365.mcp.claude.com/mcp"
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    }
  }
}
